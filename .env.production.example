SPIDER_ENV=production

SPIDER_MASTER_HOST=0.0.0.0
SPIDER_MASTER_PORT=8000
SPIDER_MASTER_STRATEGY=round_robin
SPIDER_MASTER_HEADFUL=false
SPIDER_MASTER_BROWSER_CHANNEL=
SPIDER_MASTER_CHALLENGE_WAIT=0

SPIDER_MASTER_USERNAME=admin
SPIDER_MASTER_PASSWORD=replace-with-a-strong-password
SPIDER_SESSION_SECRET=replace-with-a-long-random-session-secret
SPIDER_SESSION_TTL_SECONDS=86400
SPIDER_INTERNAL_API_TOKEN=replace-with-a-long-random-internal-token
SPIDER_SQLITE_PATH=/app/master/data/spider.db

SPIDER_SLAVE_HOST=0.0.0.0
SPIDER_SLAVE_PORT=8101
SPIDER_SLAVE_MASTER_URL=http://spider-master:8000
SPIDER_SLAVE_MASTER_TOKEN=replace-with-a-long-random-internal-token
SPIDER_SLAVE_MAX_ENVIRONMENTS=4
SPIDER_SLAVE_ENV_NAME=docker-slave-node
