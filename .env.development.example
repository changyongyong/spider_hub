SPIDER_ENV=development

SPIDER_MASTER_HOST=127.0.0.1
SPIDER_MASTER_PORT=8000
SPIDER_MASTER_STRATEGY=round_robin
SPIDER_MASTER_HEADFUL=false
SPIDER_MASTER_BROWSER_CHANNEL=
SPIDER_MASTER_CHALLENGE_WAIT=0

SPIDER_MASTER_USERNAME=admin
SPIDER_MASTER_PASSWORD=admin
SPIDER_SESSION_SECRET=dev-session-secret
SPIDER_SESSION_TTL_SECONDS=86400
SPIDER_INTERNAL_API_TOKEN=dev-internal-token

SPIDER_SLAVE_HOST=127.0.0.1
SPIDER_SLAVE_PORT=8101
SPIDER_SLAVE_MASTER_URL=http://127.0.0.1:8000
SPIDER_SLAVE_MASTER_TOKEN=dev-internal-token
SPIDER_SLAVE_MAX_ENVIRONMENTS=4
SPIDER_SLAVE_ENV_NAME=local-slave-node
