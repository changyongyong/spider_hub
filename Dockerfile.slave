FROM mcr.microsoft.com/playwright/python:v1.45.0-jammy AS runtime

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

COPY slave/requirements.txt /app/slave/requirements.txt
RUN pip install --no-cache-dir -r /app/slave/requirements.txt

COPY slave/ /app/slave/

WORKDIR /app/slave

EXPOSE 8101

CMD ["python", "-m", "src.slave"]
