FROM mcr.microsoft.com/playwright/python:v1.45.0-jammy AS runtime

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

COPY server/requirements-slave.txt /app/server/requirements-slave.txt
RUN pip install --no-cache-dir -r /app/server/requirements-slave.txt

COPY server/ /app/server/

WORKDIR /app/server

EXPOSE 8101

CMD ["python", "-m", "src.slave", "--host", "0.0.0.0", "--port", "8101"]
